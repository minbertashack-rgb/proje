## Example environment variables for local runs
# Do NOT put real secrets here. Replace placeholders in your local .env file.

# Python and runtime
DOCVERSE_PYTHON=python

# AI2 / local model
AI2_TABAN_ADRESI=http://127.0.0.1:8002/v1
AI2_MODEL=qwen-docverse
DOCVERSE_GGUF_PATH=./models/your-model.gguf
YEREL_MODEL_ETKIN=0
LLM_MODEL_PATH=./models/your-model.gguf

# OCR
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
OCR_LANG=tur+eng

# Database
DJANGO_DB_PATH=./db.sqlite3

# Debug / test
DJANGO_DEBUG=0
AI2_TEST_MODU=0
RELEASE_GATE_TEST_TIMEOUT=1200
